# ─────────────────────────────────────────────────────────────────────────────
# Overkube Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, no extra setup needed):
DATABASE_URL=sqlite:///./overkube.db

# Postgres alternative (set up with docker-compose):
# DATABASE_URL=postgresql://overkube:overkube@localhost:5432/overkube

# ── Kubernetes ────────────────────────────────────────────────────────────────
# Kubeconfig context to use. Leave blank to use the current context.
KUBE_CONTEXT=kind-overkube

# Namespace containing the simulated services.
OVERKUBE_NAMESPACE=overkube

# How often (seconds) the collector polls the K8s metrics API.
COLLECTOR_INTERVAL=30

# ── Pricing ───────────────────────────────────────────────────────────────────
# Cloud on-demand blended rates used to estimate $/month waste.
# Defaults are AWS EC2 general-purpose blended rates.
PRICE_CPU_PER_VCPU_HOUR=0.04      # $ per vCPU-hour
PRICE_MEM_PER_GB_HOUR=0.005       # $ per GB-hour

# ── GitHub (Day 6 stretch feature) ────────────────────────────────────────────
# Personal access token with repo + pull_request scopes.
# GITHUB_TOKEN=ghp_...
# GITHUB_GITOPS_REPO=your-org/gitops-manifests

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                # development | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
